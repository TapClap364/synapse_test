# =====================================================================
# Synapse AI — environment variables
# Copy to .env.local for local dev; set the same values in Vercel
# Project Settings → Environment Variables for production.
# =====================================================================

# --- Supabase (required) ---
# Frontend (public, prefixed VITE_) — anon key is safe to ship to the browser.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Backend (secret, server-only). NEVER expose to the browser.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AI provider (required for AI endpoints) ---
# Either OpenRouter (preferred — cheaper, supports Llama/Qwen) or OpenAI direct.
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# --- CORS / public URLs ---
# Comma-separated list of allowed origins for /api/* endpoints.
ALLOWED_ORIGINS=https://synapse-project-chi.vercel.app,http://localhost:5173
PUBLIC_APP_URL=https://synapse-project-chi.vercel.app

# --- Rate limiting (optional but strongly recommended) ---
# Get from https://upstash.com → Redis → REST URL/Token
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Stripe (required for billing) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Sentry (optional but recommended for production) ---
SENTRY_DSN=
VITE_SENTRY_DSN=

# --- PostHog (optional product analytics) ---
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com
