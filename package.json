    "i18next-browser-languagedetector": "^8.0.0",
    "lucide-react": "^1.9.0",
    "openai": "^4.24.0",
    "posthog-js": "^1.181.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^15.1.0",
